            local kc = io.KeyCode
            for _, hk in ipairs(self._hotkeys) do
                if hk.key == kc and hk.set ~= time() then
                    if hk.fn then
                        task.spawn(hk.fn)
                    end
                end
            end
        end
    end)

    return self
end

