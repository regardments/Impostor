            cont.Parent           = cf
            local cc = Instance.new('UICorner')
            cc.CornerRadius = UDim.new(0, R3 and 2 or 0)
            cc.Parent = cont
            local cs = Instance.new('UIStroke')
            cs.ApplyStrokeMode = 'Border'
            cs.Color           = T3.Stroke
            cs.LineJoinMode    = 'Round'
            cs.Thickness       = 1
            cs.Parent          = cont

            local fill = Instance.new('Frame')
            fill.BackgroundColor3 = T3.Primary
            fill.BackgroundTransparency = 0.6
            fill.BorderSizePixel  = 0
            fill.Name             = 'Fill'
            fill.Size             = UDim2.fromScale(0, 1)
            fill.ZIndex           = 36
            fill.Parent           = cont
            local fc = Instance.new('UICorner')
            fc.CornerRadius = UDim.new(0, R3 and 2 or 0)
            fc.Parent = fill
            local fg = Instance.new('UIGradient')
            fg.Color    = ColorSequence.new(T3.ControlGradient1, T3.ControlGradient2)
            fg.Rotation = 90
            fg.Parent   = fill

            local nameLbl = Instance.new('TextLabel')
            nameLbl.BackgroundTransparency = 1
            nameLbl.Font                   = 'SourceSans'
            nameLbl.Size                   = UDim2.fromScale(1, 1)
            nameLbl.Text                   = sliderName
            nameLbl.TextColor3             = T3.TextPrimary
            nameLbl.TextSize               = 14
            nameLbl.TextStrokeColor3       = T3.TextStroke
            nameLbl.TextStrokeTransparency = 0.8
            nameLbl.TextXAlignment         = 'Left'
            nameLbl.TextYAlignment         = 'Center'
            nameLbl.ZIndex                 = 37
            nameLbl.Parent                 = cf
            local np = Instance.new('UIPadding')
            np.PaddingLeft = UDim.new(0, 6)
            np.Parent      = nameLbl

            local valLbl = Instance.new('TextLabel')
            valLbl.BackgroundTransparency = 1
            valLbl.Font                   = 'SourceSans'
            valLbl.Size                   = UDim2.fromScale(1, 1)
            valLbl.Text                   = fmt:format(sVal)
            valLbl.TextColor3             = T3.TextPrimary
            valLbl.TextSize               = 14
            valLbl.TextStrokeColor3       = T3.TextStroke
            valLbl.TextStrokeTransparency = 0.8
            valLbl.TextXAlignment         = 'Right'
            valLbl.TextYAlignment         = 'Center'
            valLbl.ZIndex                 = 37
            valLbl.Parent                 = cf
            local vp = Instance.new('UIPadding')
            vp.PaddingRight = UDim.new(0, 6)
            vp.Parent       = valLbl

            local inputBox = Instance.new('TextBox')
            inputBox.Active               = true
            inputBox.BackgroundColor3     = T3.Window1
            inputBox.BackgroundTransparency = 0.1
            inputBox.ClearTextOnFocus     = true
            inputBox.Font                 = 'SourceSans'
            inputBox.Name                 = 'InputBox'
            inputBox.PlaceholderColor3    = T3.TextDim
            inputBox.PlaceholderText      = 'enter value'
            inputBox.Size                 = UDim2.fromScale(1, 1)
            inputBox.Text                 = ''
            inputBox.TextColor3           = T3.TextPrimary
            inputBox.TextSize             = 14
            inputBox.TextXAlignment       = 'Center'
            inputBox.TextYAlignment       = 'Center'
            inputBox.Visible              = false
            inputBox.ZIndex               = 38
            inputBox.Parent               = cont
            local ic = Instance.new('UICorner')
            ic.CornerRadius = UDim.new(0, R3 and 2 or 0)
            ic.Parent = inputBox

            local currentVal = sVal

            local function applyValue(v)
                local clamped = math.clamp(v, sMin, sMax)
                local rounded = math.floor((clamped + sStep / 2) / sStep) * sStep
                local fillPct = (rounded - sMin) / (sMax - sMin)
                currentVal   = rounded
                valLbl.Text  = fmt:format(rounded)
                tween(fill, {Size = UDim2.fromScale(fillPct, 1)}, 0.2, 1)
                if callback then task.spawn(callback, rounded) end
            end

            applyValue(sVal)

            inputBox.FocusLost:Connect(function()
                local n = tonumber(inputBox.Text)
                if n then applyValue(n) end
                inputBox.Visible = false
            end)

            local dcon, acon
            cont.InputBegan:Connect(function(io)
                if io.UserInputType.Name == 'MouseButton1' then
                    local pos = cont.AbsolutePosition
                    local w   = cont.AbsoluteSize.X

                    local raw     = math.clamp((Vector2.new(io.Position.X, io.Position.Y) - pos).X / w, 0, 1)
                    local scaled  = raw * (sMax - sMin) + sMin
                    applyValue(scaled)

                    local targetSz = UDim2.fromScale((currentVal - sMin) / (sMax - sMin), 1)
                    acon = renderService.RenderStepped:Connect(function(dt)
                        fill.Size = fill.Size:lerp(targetSz, 1 - 1e-12 ^ dt)
                    end)
                    dcon = inputService.InputChanged:Connect(function(io2)
                        if io2.UserInputType.Name == 'MouseMovement' then
                            local r2 = math.clamp((Vector2.new(io2.Position.X, io2.Position.Y) - pos).X / w, 0, 1)
                            applyValue(r2 * (sMax - sMin) + sMin)
                            targetSz = UDim2.fromScale((currentVal - sMin) / (sMax - sMin), 1)
                        end
                    end)
                elseif io.UserInputType.Name == 'MouseButton2' then
                    inputBox.Visible = true
                    inputBox:CaptureFocus()
                end
            end)
            cont.InputEnded:Connect(function(io)
                if io.UserInputType.Name == 'MouseButton1' then
                    if dcon then dcon:Disconnect() end
                    if acon then acon:Disconnect() end
                    tween(fill, {Size = UDim2.fromScale((currentVal - sMin) / (sMax - sMin), 1)}, 0.2, 1)
