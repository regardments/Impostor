            btnFrame2.Name             = 'DropBtn'
            btnFrame2.Position         = UDim2.new(0.5, 0, 0, 2)
            btnFrame2.Size             = UDim2.new(1, -6, 0, 16)
            btnFrame2.ZIndex           = 35
            btnFrame2.Parent           = sensor
            local dbc = Instance.new('UICorner')
            dbc.CornerRadius = UDim.new(0, R3 and 2 or 0)
            dbc.Parent = btnFrame2
            local dbs = Instance.new('UIStroke')
            dbs.ApplyStrokeMode = 'Border'
            dbs.Color           = T3.Stroke
            dbs.LineJoinMode    = 'Round'
            dbs.Thickness       = 1
            dbs.Parent          = btnFrame2

            local dropLbl = Instance.new('TextLabel')
            dropLbl.BackgroundTransparency = 1
            dropLbl.Font                   = 'SourceSans'
            dropLbl.Size                   = UDim2.fromScale(1, 1)
            dropLbl.Text                   = dropName
            dropLbl.TextColor3             = T3.TextPrimary
            dropLbl.TextSize               = 14
            dropLbl.TextStrokeColor3       = T3.TextStroke
            dropLbl.TextStrokeTransparency = 0.8
            dropLbl.TextXAlignment         = 'Center'
            dropLbl.TextYAlignment         = 'Center'
            dropLbl.ZIndex                 = 36
            dropLbl.Parent                 = btnFrame2

            local arrowLbl = Instance.new('TextLabel')
            arrowLbl.AnchorPoint          = Vector2.new(1, 0.5)
            arrowLbl.BackgroundTransparency = 1
            arrowLbl.Font                 = 'SourceSans'
            arrowLbl.Position             = UDim2.new(1, -4, 0.5, 0)
            arrowLbl.Size                 = UDim2.fromOffset(12, 12)
            arrowLbl.Text                 = '▼'
            arrowLbl.TextColor3           = T3.TextDim
            arrowLbl.TextSize             = 10
            arrowLbl.TextXAlignment       = 'Center'
            arrowLbl.TextYAlignment       = 'Center'
            arrowLbl.ZIndex               = 36
            arrowLbl.Parent               = btnFrame2

            local dropMenu = Instance.new('ScrollingFrame')
            dropMenu.AutomaticCanvasSize        = 'Y'
            dropMenu.BackgroundColor3           = T3.Window3
            dropMenu.BorderSizePixel            = 0
            dropMenu.BottomImage                = 'rbxassetid://9416839567'
            dropMenu.CanvasSize                 = UDim2.fromOffset(0, 0)
            dropMenu.ClipsDescendants           = true
            dropMenu.MidImage                   = 'rbxassetid://9416839567'
            dropMenu.Name                       = 'DropMenu'
            dropMenu.Position                   = UDim2.fromOffset(3, 20)
            dropMenu.ScrollBarImageTransparency = 0.9
            dropMenu.ScrollBarThickness         = 1
            dropMenu.ScrollingDirection         = 'Y'
            dropMenu.Size                       = UDim2.new(1, -6, 0, 0)
            dropMenu.TopImage                   = 'rbxassetid://9416839567'
            dropMenu.ZIndex                     = 35
            dropMenu.Parent                     = cf
            do
                local ds = Instance.new('UIStroke')
                ds.ApplyStrokeMode = 'Border'
                ds.Color           = T3.Stroke
                ds.Thickness       = 1
                ds.Parent          = dropMenu
                local dl = Instance.new('UIListLayout')
                dl.Padding             = UDim.new(0, 2)
                dl.FillDirection       = 'Vertical'
                dl.HorizontalAlignment = 'Center'
                dl.VerticalAlignment   = 'Top'
                dl.SortOrder           = 'LayoutOrder'
                dl.Parent              = dropMenu
                local dp = Instance.new('UIPadding')
                dp.PaddingTop = UDim.new(0, 2)
                dp.Parent     = dropMenu
            end

            local optionItems = {}

            local function addOption(optText)
                local ob = Instance.new('TextButton')
                ob.AutoButtonColor  = false
                ob.BackgroundColor3 = T3.Button1
                ob.BorderSizePixel  = 0
                ob.Font             = 'SourceSans'
                ob.Name             = optText
                ob.Size             = UDim2.new(1, -4, 0, 16)
                ob.Text             = optText
                ob.TextColor3       = T3.TextPrimary
                ob.TextSize         = 14
                ob.TextStrokeColor3 = T3.TextStroke
                ob.TextStrokeTransparency = 0.8
                ob.ZIndex           = 36
                ob.Parent           = dropMenu
                local oc = Instance.new('UICorner')
                oc.CornerRadius = UDim.new(0, R3 and 2 or 0)
                oc.Parent = ob

                ob.MouseEnter:Connect(function()
                    tween(ob, {BackgroundColor3 = T3.Button2}, 0.15, 1)
                end)
                ob.MouseLeave:Connect(function()
                    if selected == optText then
                        tween(ob, {BackgroundColor3 = T3.Button3}, 0.15, 1)
                    else
                        tween(ob, {BackgroundColor3 = T3.Button1}, 0.15, 1)
                    end
                end)
                ob.MouseButton1Click:Connect(function()
                    if selected and optionItems[selected] then
                        tween(optionItems[selected], {BackgroundColor3 = T3.Button1}, 0.15, 1)
                    end
                    selected = optText
                    tween(ob, {BackgroundColor3 = T3.Button3}, 0.15, 1)
                    dropLbl.Text = optText
                    tween(arrowLbl, {TextColor3 = T3.Primary}, 0.2, 1)
                    if callback then task.spawn(callback, optText) end

                    opened = false
                    tween(dropMenu, {Size = UDim2.new(1, -6, 0, 0)}, 0.2, 1)
                    tween(cf, {Size = UDim2.new(1, 0, 0, 20)}, 0.2, 1)
                    tween(arrowLbl, {Rotation = 0}, 0.2, 1)
                end)
                optionItems[optText] = ob
            end

            for _, opt in ipairs(options or {}) do
                addOption(tostring(opt))
            end

            sensor.MouseEnter:Connect(function()
                tween(btnFrame2, {BackgroundColor3 = T3.Button2}, 0.2, 1)
                tween(dbs, {Color = T3.StrokeHover}, 0.2, 1)
            end)
            sensor.MouseLeave:Connect(function()
                if not opened then
                    tween(btnFrame2, {BackgroundColor3 = T3.Button1}, 0.2, 1)
                    tween(dbs, {Color = T3.Stroke}, 0.2, 1)
                end
            end)
            sensor.MouseButton1Click:Connect(function()
                opened = not opened
                if opened then
                    local count = 0
                    for _ in pairs(optionItems) do count = count + 1 end
                    local h2 = math.min(count * 18 + 4, 100)
                    tween(dropMenu, {Size = UDim2.new(1, -6, 0, h2)}, 0.2, 1)
                    tween(cf, {Size = UDim2.new(1, 0, 0, 20 + h2)}, 0.2, 1)
                    tween(arrowLbl, {Rotation = 180}, 0.2, 1)
                    tween(btnFrame2, {BackgroundColor3 = T3.Button3}, 0.2, 1)
                else
                    tween(dropMenu, {Size = UDim2.new(1, -6, 0, 0)}, 0.2, 1)
                    tween(cf, {Size = UDim2.new(1, 0, 0, 20)}, 0.2, 1)
                    tween(arrowLbl, {Rotation = 0}, 0.2, 1)
                    tween(btnFrame2, {BackgroundColor3 = T3.Button1}, 0.2, 1)
                end
            end)

            local obj = {}
            function obj:Get() return selected end
            function obj:Set(opt)
                if optionItems[opt] then
                    if selected and optionItems[selected] then
                        optionItems[selected].BackgroundColor3 = T3.Button1
                    end
                    selected = opt
                    dropLbl.Text = opt
                    optionItems[opt].BackgroundColor3 = T3.Button3
                end
            end
            function obj:AddOption(opt)
                addOption(tostring(opt))
            end
            function obj:SetOptions(newOpts)
                for _, ob in pairs(optionItems) do ob:Destroy() end
                optionItems = {}
                selected    = nil
                dropLbl.Text = dropName
                for _, opt in ipairs(newOpts) do addOption(tostring(opt)) end
            end
            function obj:SetText(t) dropLbl.Text = tostring(t) end
            return obj
        end

        return setmetatable(sec, secMeta)
    end

    return setmetatable(tab, tabMeta)
end

function Library:Notify(title, message, duration)
    local T   = self._theme
    local dur = duration or 3

    local notifFrame = Instance.new('Frame')
    notifFrame.AnchorPoint      = Vector2.new(1, 0)
    notifFrame.BackgroundColor3 = T.Window2
    notifFrame.BorderSizePixel  = 0
    notifFrame.Name             = 'Notif'
    notifFrame.Size             = UDim2.fromOffset(200, 70)
    notifFrame.Visible          = true
    notifFrame.ZIndex           = 3000
    do
        local ns = Instance.new('UIStroke')
        ns.ApplyStrokeMode = 'Border'
        ns.Color           = T.Stroke
        ns.LineJoinMode    = 'Round'
        ns.Thickness       = 1
        ns.Parent          = notifFrame
        local nt = Instance.new('Frame')
        nt.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        nt.BorderSizePixel  = 0
        nt.Position         = UDim2.fromOffset(0, -1)
        nt.Size             = UDim2.new(1, 0, 0, 1)
        nt.ZIndex           = 3005
        nt.Parent           = notifFrame
        local ntg = Instance.new('UIGradient')
        ntg.Color  = ColorSequence.new(T.Primary, T.Secondary)
        ntg.Parent = nt
    end

    local ntb = Instance.new('Frame')
    ntb.BackgroundColor3 = T.Window1
    ntb.BorderColor3     = T.Inset1
    ntb.BorderMode       = 'Inset'
    ntb.BorderSizePixel  = 1
    ntb.ClipsDescendants = true
    ntb.Name             = 'NTitleBar'
    ntb.Size             = UDim2.new(1, 0, 0, 26)
    ntb.ZIndex           = 3001
    ntb.Parent           = notifFrame
    do
        local ntbs = Instance.new('UIStroke')
        ntbs.ApplyStrokeMode = 'Border'
        ntbs.Color           = T.Stroke
        ntbs.Thickness       = 1
        ntbs.Parent          = ntb
        local nti = Instance.new('ImageLabel')
        nti.BackgroundTransparency = 1
        nti.Image                  = 'rbxassetid://9865915364'
        nti.ImageColor3            = T.Primary
        nti.Position               = UDim2.fromOffset(2, 2)
        nti.Size                   = UDim2.fromOffset(22, 22)
        nti.ZIndex                 = 3002
        nti.Parent                 = ntb
        local ntlbl = Instance.new('TextLabel')
        ntlbl.BackgroundTransparency = 1
        ntlbl.Font                   = 'SourceSans'
        ntlbl.Position               = UDim2.fromOffset(28, 0)
        ntlbl.Size                   = UDim2.new(1, -28, 1, 0)
        ntlbl.Text                   = title or 'Notification'
        ntlbl.TextColor3             = T.TextPrimary
        ntlbl.TextSize               = 15
        ntlbl.TextStrokeColor3       = T.TextStroke
        ntlbl.TextStrokeTransparency = 0.8
        ntlbl.TextXAlignment         = 'Left'
        ntlbl.TextYAlignment         = 'Center'
        ntlbl.ZIndex                 = 3002
        ntlbl.Parent                 = ntb
        local ntp = Instance.new('UIPadding')
        ntp.PaddingLeft = UDim.new(0, 4)
        ntp.Parent      = ntlbl
    end

    local nreg = Instance.new('Frame')
    nreg.BackgroundColor3 = T.Window2
    nreg.BorderColor3     = T.Inset2
    nreg.BorderMode       = 'Inset'
    nreg.BorderSizePixel  = 1
    nreg.ClipsDescendants = true
    nreg.Name             = 'NRegion'
    nreg.Position         = UDim2.fromOffset(0, 27)
    nreg.Size             = UDim2.new(1, 0, 1, -27)
    nreg.ZIndex           = 3001
    nreg.Parent           = notifFrame
    local ndesc = Instance.new('TextLabel')
    ndesc.BackgroundTransparency = 1
    ndesc.Font                   = 'SourceSans'
    ndesc.Size                   = UDim2.fromScale(1, 1)
    ndesc.Text                   = message or ''
    ndesc.TextColor3             = T.TextPrimary
    ndesc.TextSize               = 14
    ndesc.TextStrokeColor3       = T.TextStroke
    ndesc.TextStrokeTransparency = 0.8
    ndesc.TextWrapped            = true
    ndesc.TextXAlignment         = 'Left'
    ndesc.TextYAlignment         = 'Top'
    ndesc.ZIndex                 = 3002
    ndesc.Parent                 = nreg
    local ndp = Instance.new('UIPadding')
    ndp.PaddingLeft = UDim.new(0, 6)
    ndp.PaddingTop  = UDim.new(0, 4)
    ndp.Parent      = ndesc

    local yOffset = 10
    for _, n in ipairs(self._notifs) do
        yOffset = yOffset + n.AbsoluteSize.Y + 6
    end
    notifFrame.Position = UDim2.new(1, 10, 1, -(yOffset))
    notifFrame.Parent   = self._notifCont
    table.insert(self._notifs, notifFrame)

    tween(notifFrame, {Position = UDim2.new(1, 0, 1, -(yOffset))}, 0.3, 1)

    task.delay(dur, function()
        local idx = table.find(self._notifs, notifFrame)
        if idx then table.remove(self._notifs, idx) end
        tween(notifFrame, {Size = UDim2.fromOffset(notifFrame.AbsoluteSize.X, 0)}, 0.4, 1).Completed:Wait()
        notifFrame:Destroy()
    end)
end

function Library:Destroy()
    if self._hkCon then self._hkCon:Disconnect() end
    if self._uiScreen then self._uiScreen:Destroy() end
    Library._activeLib = nil
end

function Library.DestroyLib()
    if Library._activeLib then
        Library._activeLib:Destroy()
    end
end

return Library
