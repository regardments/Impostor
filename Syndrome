        function secMeta:NewSlider(sliderName, _, minVal, maxVal, startVal, step, callback)
            local T3    = sec._tab._lib._theme
            local R3    = sec._tab._lib._rounding
            local sMin  = minVal   or 0
            local sMax  = maxVal   or 100
            local sStep = step     or 1
            local sVal  = startVal or sMin

            local fmt
            if sStep >= 1 then fmt = '%d'
            elseif sStep >= 0.1 then fmt = '%.1f'
            elseif sStep >= 0.01 then fmt = '%.2f'
            elseif sStep >= 0.001 then fmt = '%.3f'
            else fmt = '%.4f'
            end

            local cf = makeControl(20)

            local cont = Instance.new('Frame')
            cont.BackgroundColor3 = T3.Button1
