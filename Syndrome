local function tween(object, props, duration, style)
    local styleEnum = Enum.EasingStyle
    local styles    = { styleEnum.Exponential, styleEnum.Linear }
    local info      = TweenInfo.new(duration, styles[style], Enum.EasingDirection.Out)
    local t         = tweenService:Create(object, info, props)
    t:Play()
    return t
end

