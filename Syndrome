				BackButton.BackgroundTransparency = 1
				BackButton.Name = "Back"
				BackButton.Size = UDim2.fromScale(1, 1)
				BackButton.Text = ""
				BackButton.ZIndex = 34
				BackButton.Parent = ControlFrame

