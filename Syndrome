                vc2s.Color     = Color3.fromRGB(255, 255, 255)
                vc2s.Thickness = 1
                vc2s.Parent    = valCursor2

                local function cartToPolar(x2, y2)
                    return math.sqrt(x2 * x2 + y2 * y2), math.atan2(y2, x2)
                end
                local function polarToCart(r2, th)
                    return r2 * math.cos(th), r2 * math.sin(th)
                end

                local function applyHSV()
                    color = Color3.fromHSV(h, s2, v)
                    display.BackgroundColor3 = color
                    valCont.BackgroundColor3 = Color3.fromHSV(h, s2, 1)
                    if callback then task.spawn(callback, color) end
                end

                local function moveCursor()
                    local radius = s2 / 2
                    local theta  = (h * (math.pi * 2)) - (math.pi * 2)
                    local cx, cy = polarToCart(radius, theta)
                    cursor2.Position = UDim2.fromScale(cx + 0.5, cy + 0.5)
                    valCursor2.Position = UDim2.fromScale(v, 0)
                end

                moveCursor()
                applyHSV()

                local wDcon, wAcon
                wheel.InputBegan:Connect(function(io)
                    if io.UserInputType.Name == 'MouseButton1' then
                        local wp  = wheel.AbsolutePosition
                        local ws  = wheel.AbsoluteSize.X

                        local function calc(pos)
                            local x2 = pos.X / ws - 0.5
                            local y2 = pos.Y / ws - 0.5
                            local r2, th = cartToPolar(x2, y2)
                            local cm = math.sqrt(x2 * x2 + y2 * y2)
                            if cm > 0.5 then
                                local nx, ny = polarToCart(r2 - (cm - 0.5), th)
                                x2, y2 = nx, ny
                                cm = math.sqrt(x2 * x2 + y2 * y2)
                            end
                            h  = ((th / math.pi + 2) / 2) % 1
                            s2 = math.clamp(cm * 2, 0, 1)
                            cursor2.Position = UDim2.fromScale(x2 + 0.5, y2 + 0.5)
                            applyHSV()
                        end

                        local p0 = Vector2.new(io.Position.X, io.Position.Y) - wp
                        calc(p0)

                        wAcon = renderService.RenderStepped:Connect(function(dt)
                        end)
                        wDcon = inputService.InputChanged:Connect(function(io2)
                            if io2.UserInputType.Name == 'MouseMovement' then
                                local p2 = Vector2.new(io2.Position.X, io2.Position.Y) - wp
                                calc(p2)
                            end
                        end)
                    end
                end)
                wheel.InputEnded:Connect(function(io)
                    if io.UserInputType.Name == 'MouseButton1' then
                        if wDcon then wDcon:Disconnect() end
                        if wAcon then wAcon:Disconnect() end
                    end
                end)

                local vDcon, vAcon
                valCont.InputBegan:Connect(function(io)
                    if io.UserInputType.Name == 'MouseButton1' then
                        local vp = valCont.AbsolutePosition
                        local vw = valCont.AbsoluteSize.X

                        local function calc2(pos)
                            v = math.clamp((pos.X - vp.X) / vw, 0, 1)
                            valCursor2.Position = UDim2.fromScale(v, 0)
                            applyHSV()
                        end

                        calc2(Vector2.new(io.Position.X, io.Position.Y))
                        vDcon = inputService.InputChanged:Connect(function(io2)
                            if io2.UserInputType.Name == 'MouseMovement' then
                                calc2(Vector2.new(io2.Position.X, io2.Position.Y))
                            end
                        end)
                    end
                end)
                valCont.InputEnded:Connect(function(io)
                    if io.UserInputType.Name == 'MouseButton1' then
                        if vDcon then vDcon:Disconnect() end
                    end
                end)

                openWin = pw

                task.spawn(function()
                    pw.Size = UDim2.fromOffset(300, 30)
                    tween(pw, {Size = UDim2.fromOffset(300, 300)}, 0.4, 1)
                end)
            end)

            local obj = {}
            function obj:Get() return color end
            function obj:Set(c)
                color = c
                display.BackgroundColor3 = c
                local nh, ns, nv = c:ToHSV()
                h, s2, v = nh, ns, nv
            end
            function obj:SetText(t) lbl.Text = tostring(t) end
            return obj
        end

